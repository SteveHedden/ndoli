@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix schema:  <https://schema.org/> .
@prefix rel:     <https://ndoli.dev/rel/> .

# ── Ontology Declaration ──────────────────────────────────────────────────────

<https://ndoli.dev/ontology>
    a owl:Ontology ;
    rdfs:label "Personal KG Ontology" ;
    rdfs:comment "Ontology for a personal professional knowledge graph — contacts, opportunities, and projects." ;
    owl:versionInfo "0.2" .

# ── Classes ───────────────────────────────────────────────────────────────────
#
# Each class is declared as both an OWL class and a SHACL NodeShape.
# OWL handles semantics (inference, domain/range, reasoning).
# SHACL property shapes document expected structure for each class.
# No sh:minCount or sh:maxCount — shapes are descriptive, not enforced.

rel:Opportunity a owl:Class, sh:NodeShape ;
    sh:targetClass rel:Opportunity ;
    rdfs:label "Opportunity" ;
    rdfs:comment "A business, research, or collaboration opportunity being tracked." ;
    sh:property [ sh:path schema:name    ; sh:datatype xsd:string ] ;
    sh:property [ sh:path rel:status     ; sh:datatype xsd:string ] ;
    sh:property [ sh:path rel:contact    ; sh:class foaf:Person   ] ;
    sh:property [ sh:path rel:deadline   ; sh:datatype xsd:date   ] ;
    sh:property [ sh:path rel:value      ; sh:datatype xsd:string ] .

rel:Project a owl:Class, sh:NodeShape ;
    sh:targetClass rel:Project ;
    rdfs:label "Project" ;
    rdfs:comment "An active or planned project." ;
    sh:property [ sh:path schema:name ; sh:datatype xsd:string ] ;
    sh:property [ sh:path rel:status  ; sh:datatype xsd:string ] ;
    sh:property [ sh:path rel:project                          ] .

rel:Engagement a owl:Class, sh:NodeShape ;
    sh:targetClass rel:Engagement ;
    rdfs:label "Engagement" ;
    rdfs:comment "A paid consulting or contracting engagement." ;
    sh:property [ sh:path schema:name ; sh:datatype xsd:string ] ;
    sh:property [ sh:path rel:status  ; sh:datatype xsd:string ] ;
    sh:property [ sh:path rel:contact ; sh:class foaf:Person   ] .

# ── Contact / Relationship Properties ────────────────────────────────────────

rel:metVia a owl:DatatypeProperty ;
    rdfs:label "met via" ;
    rdfs:comment "How you first encountered this person." ;
    rdfs:domain foaf:Person ;
    rdfs:range xsd:string .

rel:firstContact a owl:DatatypeProperty ;
    rdfs:label "first contact date" ;
    rdfs:domain foaf:Person ;
    rdfs:range xsd:date .

rel:lastContact a owl:DatatypeProperty ;
    rdfs:label "last contact date" ;
    rdfs:domain foaf:Person ;
    rdfs:range xsd:date .

rel:status a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "Current status. People: active, warm, cold, closed. Opportunities: active, pending, closed-won, closed-lost, deferred." ;
    rdfs:range xsd:string .

rel:researchArea a owl:DatatypeProperty ;
    rdfs:label "research/focus area" ;
    rdfs:domain foaf:Person ;
    rdfs:range xsd:string .

# ── Link / Reference Properties ───────────────────────────────────────────────

rel:email a owl:ObjectProperty ;
    rdfs:label "email thread link" ;
    rdfs:comment "Link to an email thread relevant to this entity." .

rel:publication a owl:ObjectProperty ;
    rdfs:label "publication" ;
    rdfs:domain foaf:Person .

rel:project a owl:ObjectProperty ;
    rdfs:label "project link" ;
    rdfs:comment "Link to a GitHub repo or project URL." .

# ── Observation ───────────────────────────────────────────────────────────────

rel:Observation a owl:Class, sh:NodeShape ;
    sh:targetClass rel:Observation ;
    rdfs:label "Observation" ;
    rdfs:comment "A dated, sourced interaction or finding. Immutable — create a new instance rather than editing." ;
    sh:property [ sh:path rel:involves        ] ;
    sh:property [ sh:path rel:observationDate ; sh:datatype xsd:date   ] ;
    sh:property [ sh:path rel:interactionType ; sh:datatype xsd:string ] ;
    sh:property [ sh:path rel:content         ; sh:datatype xsd:string ] ;
    sh:property [ sh:path rel:source                                   ] .

rel:involves a owl:ObjectProperty ;
    rdfs:label "involves" ;
    rdfs:domain rel:Observation ;
    rdfs:comment "Entity (person, org, opportunity, project) this observation concerns." .

rel:observationDate a owl:DatatypeProperty ;
    rdfs:label "observation date" ;
    rdfs:domain rel:Observation ;
    rdfs:range xsd:date .

rel:interactionType a owl:DatatypeProperty ;
    rdfs:label "interaction type" ;
    rdfs:domain rel:Observation ;
    rdfs:range xsd:string ;
    rdfs:comment "meeting, call, email, async, read, event" .

rel:content a owl:DatatypeProperty ;
    rdfs:label "content" ;
    rdfs:domain rel:Observation ;
    rdfs:range xsd:string ;
    rdfs:comment "What happened or was learned. Be specific — this is the evidence layer." .

rel:source a owl:ObjectProperty ;
    rdfs:label "source" ;
    rdfs:domain rel:Observation ;
    rdfs:comment "URI pointing to where this observation is documented — a file path, email thread, URL, calendar event, or any other locatable artifact. Use as many as apply." .

# ── Opportunity Properties ────────────────────────────────────────────────────

rel:opportunity a owl:ObjectProperty ;
    rdfs:label "opportunity" ;
    rdfs:domain foaf:Person ;
    rdfs:range rel:Opportunity .

rel:contact a owl:ObjectProperty ;
    rdfs:label "primary contact" ;
    rdfs:domain rel:Opportunity ;
    rdfs:range foaf:Person .

rel:deadline a owl:DatatypeProperty ;
    rdfs:label "deadline" ;
    rdfs:domain rel:Opportunity ;
    rdfs:range xsd:date .

rel:value a owl:DatatypeProperty ;
    rdfs:label "estimated value" ;
    rdfs:domain rel:Opportunity ;
    rdfs:range xsd:string .
