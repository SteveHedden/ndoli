@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix schema:  <https://schema.org/> .
@prefix ndoli:   <https://ndoli.dev/> .

# ── Ontology Declaration ──────────────────────────────────────────────────────

<https://ndoli.dev/ontology>
    a owl:Ontology ;
    rdfs:label "Personal KG Ontology" ;
    rdfs:comment "Ontology for a personal professional knowledge graph — contacts, opportunities, and projects." ;
    owl:versionInfo "0.3" .

# ── Classes ───────────────────────────────────────────────────────────────────
#
# Each class is declared as both an OWL class and a SHACL NodeShape.
# OWL handles semantics; SHACL shapes document expected structure.
# Shapes are descriptive, not enforced (no sh:minCount / sh:maxCount).
#
# Standard vocab used where it fits:
#   schema:Project        — built-in schema.org class, no redeclaration needed
#   schema:endDate        — opportunity deadline
#   schema:knowsAbout     — research / focus areas on foaf:Person
#   schema:codeRepository — repo URL on schema:Project
#   dcterms:date          — date of an observation
#   schema:description    — content / notes on an observation
#   dcterms:source        — provenance URI on an observation

ndoli:Opportunity a owl:Class, sh:NodeShape ;
    sh:targetClass ndoli:Opportunity ;
    rdfs:label "Opportunity" ;
    rdfs:comment "A business, research, or collaboration opportunity being tracked." ;
    sh:property [ sh:path schema:name    ; sh:datatype xsd:string ] ;
    sh:property [ sh:path ndoli:status   ; sh:datatype xsd:string ] ;
    sh:property [ sh:path ndoli:contact  ; sh:class foaf:Person   ] ;
    sh:property [ sh:path schema:endDate ; sh:datatype xsd:date   ] ;
    sh:property [ sh:path ndoli:value    ; sh:datatype xsd:string ] .

schema:Project a sh:NodeShape ;
    sh:targetClass schema:Project ;
    sh:property [ sh:path schema:name           ; sh:datatype xsd:string ] ;
    sh:property [ sh:path ndoli:status          ; sh:datatype xsd:string ] ;
    sh:property [ sh:path schema:codeRepository                          ] .

ndoli:Engagement a owl:Class, sh:NodeShape ;
    sh:targetClass ndoli:Engagement ;
    rdfs:label "Engagement" ;
    rdfs:comment "A paid consulting or contracting engagement." ;
    sh:property [ sh:path schema:name   ; sh:datatype xsd:string ] ;
    sh:property [ sh:path ndoli:status  ; sh:datatype xsd:string ] ;
    sh:property [ sh:path ndoli:contact ; sh:class foaf:Person   ] .

# ── Contact / Relationship Properties ────────────────────────────────────────

ndoli:metVia a owl:DatatypeProperty ;
    rdfs:label "met via" ;
    rdfs:comment "How you first encountered this person." ;
    rdfs:domain foaf:Person ;
    rdfs:range xsd:string .

ndoli:firstContact a owl:DatatypeProperty ;
    rdfs:label "first contact date" ;
    rdfs:domain foaf:Person ;
    rdfs:range xsd:date .

ndoli:lastContact a owl:DatatypeProperty ;
    rdfs:label "last contact date" ;
    rdfs:domain foaf:Person ;
    rdfs:range xsd:date .

ndoli:status a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "Current status. People: active, warm, cold, closed. Opportunities: active, pending, closed-won, closed-lost, deferred." ;
    rdfs:range xsd:string .

ndoli:publication a owl:ObjectProperty ;
    rdfs:label "publication" ;
    rdfs:comment "Link to a publication (arXiv, DOI, etc.) authored by or relevant to this person." ;
    rdfs:domain foaf:Person .

# ── Observation ───────────────────────────────────────────────────────────────

ndoli:Observation a owl:Class, sh:NodeShape ;
    sh:targetClass ndoli:Observation ;
    rdfs:label "Observation" ;
    rdfs:comment "A dated, sourced interaction or finding. Immutable — create a new instance rather than editing." ;
    sh:property [ sh:path ndoli:involves         ] ;
    sh:property [ sh:path dcterms:date           ; sh:datatype xsd:date   ] ;
    sh:property [ sh:path ndoli:interactionType  ; sh:datatype xsd:string ] ;
    sh:property [ sh:path schema:description     ; sh:datatype xsd:string ] ;
    sh:property [ sh:path dcterms:source                                  ] .

ndoli:involves a owl:ObjectProperty ;
    rdfs:label "involves" ;
    rdfs:domain ndoli:Observation ;
    rdfs:comment "Entity (person, org, opportunity, project) this observation concerns." .

ndoli:interactionType a owl:DatatypeProperty ;
    rdfs:label "interaction type" ;
    rdfs:domain ndoli:Observation ;
    rdfs:range xsd:string ;
    rdfs:comment "meeting, call, email, async, read, event" .

# ── Opportunity Properties ────────────────────────────────────────────────────

ndoli:opportunity a owl:ObjectProperty ;
    rdfs:label "opportunity" ;
    rdfs:domain foaf:Person ;
    rdfs:range ndoli:Opportunity .

ndoli:contact a owl:ObjectProperty ;
    rdfs:label "primary contact" ;
    rdfs:domain ndoli:Opportunity ;
    rdfs:range foaf:Person .

ndoli:value a owl:DatatypeProperty ;
    rdfs:label "estimated value" ;
    rdfs:domain ndoli:Opportunity ;
    rdfs:range xsd:string .
